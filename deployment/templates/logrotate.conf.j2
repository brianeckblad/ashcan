# ============================================================================
# LOGROTATE CONFIGURATION
# ============================================================================
# Template: deployment/templates/logrotate.conf.j2
# Purpose:
#   - Automatically rotates log files to prevent disk space issues
#   - Compresses old logs (gzip) to save space
#   - Enforces retention policy (keeps {{ log_retention_days }} rotated files)
#
# Generated by: setup.yml playbook during deployment
# Location on server: /etc/logrotate.d/{{ app_name }}
#
# How it works:
#   1. Runs daily (via cron)
#   2. Rotates when file reaches {{ log_max_size | default('10M') }} OR daily (whichever comes first)
#   3. Renames app.log to app.log-20240223
#   4. Compresses to app.log-20240223.gz
#   5. Keeps {{ log_retention_days }} rotated files, deletes older
#   6. Creates new app.log with correct permissions
#
# File naming:
#   - app.log (current file being written)
#   - app.log-20240223 (rotated yesterday)
#   - app.log-20240222.gz (compressed 2 days ago)
#
# Disk space example:
#   Without rotation: app.log could grow to 100GB+ over time
#   With rotation: {{ log_retention_days }} rotated files capped at {{ log_max_size | default('10M') }} each
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
#     Adjust log_retention_days in group_vars/vault.yml
# ============================================================================

{{ log_dir }}/app.log
{{ log_dir }}/error.log
{{ log_dir }}/service.log
{{ log_dir }}/cleanup.log
{{ log_dir }}/access.log
{{ log_dir }}/monitor.log
{
    # Rotate daily
    daily

    # Keep {{ log_retention_days }} rotated logs
    rotate {{ log_retention_days }}

    # Compress old logs (gzip)
    compress

    # Delay compression until next rotation (so current .log.1 is not compressed)
    delaycompress

    # Don't rotate if log is empty
    notifempty

    # Truncate the active file in place after copying it to the rotated file.
    # This keeps Supervisor/Gunicorn file descriptors valid.
    copytruncate

    # Don't error if log file is missing
    missingok

    # Use date as suffix for rotated files (e.g., app.log-20231225)
    dateext
    dateformat -%Y%m%d

    # Rotate when file reaches log_max_size (in addition to daily)
    size {{ log_max_size | default('10M') }}

    # Rotate as the runtime user so app-owned logs stay app-owned.
    su {{ app_runtime_user }} {{ app_name }}
}
